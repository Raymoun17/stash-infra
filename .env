COMPOSE_PROJECT_NAME=stash
NETWORK_NAME=stash-network

DB_CONTAINER_NAME=stash-db
DB_HOST_ALIAS=db
DB_PORT=5432
DB_VOLUME_NAME=pgdata
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=stash

BFF_CONTAINER_NAME=stash-bff
BFF_HOST_ALIAS=bff
BFF_PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://admin:admin@db:5432/stash
JWT_SECRET=stash-local-jwt-secret-change-in-production
REFRESH_COOKIE_PATH=/api/auth
REFRESH_COOKIE_SECURE=false
SCRAPER_MODE=remote
SCRAPER_WORKER_URL=http://scraper-worker:8000
SCRAPER_SERVICE_TOKEN=stash-local-service-token
INTEGRATION_TIMEOUT_MS=20000
INTEGRATION_MAX_HTML_BYTES=10000000

UI_CONTAINER_NAME=stash-ui
UI_HOST_ALIAS=ui
UI_PORT=3001
NEXT_PUBLIC_API_URL=/api
BFF_INTERNAL_URL=http://bff:3000

SCRAPER_CONTAINER_NAME=stash-scraper-worker
SCRAPER_HOST_ALIAS=scraper-worker
SCRAPER_PORT=8000
SCRAPER_BIND_HOST=0.0.0.0
SCRAPER_MAX_CONCURRENCY=2
