# Copy to .env and replace every change-me value.
POSTGRES_USER=stash
POSTGRES_PASSWORD=change-me-use-a-long-random-password
POSTGRES_DB=stash
JWT_SECRET=change-me-use-at-least-32-random-bytes
SCRAPER_SERVICE_TOKEN=change-me-use-a-long-random-token
GEMINI_API_KEY=change-me-use-a-long-random-token

WEB_DOMAIN=stash.your-domain.example
API_DOMAIN=api.stash.your-domain.example
CORS_ORIGINS=https://stash.your-domain.example
NEXT_PUBLIC_API_URL=/api
BFF_INTERNAL_URL=http://bff:3000
UI_PORT=3000
BFF_PORT=3001
NEXT_PUBLIC_NOTIFICATION_POLL_INTERVAL_MS=60000
REFRESH_COOKIE_SECURE=false
SCRAPER_MAX_CONCURRENCY=2
SCRAPER_LOG_LEVEL=INFO
PRICE_REFRESH_INTERVAL_MS=8640000
NEXT_PUBLIC_NOTIFICATION_POLL_INTERVAL_MS=8640000

# Optional standalone deployment overrides. By default, Compose builds from
# sibling directories for local development. Uncomment these to pull from Git.
# For reproducible production deploys, replace `main` with a tag or commit SHA.
# Public repositories (no authentication):
# DB_BUILD_CONTEXT=https://github.com/Raymoun17/stash-db.git#main
# BFF_BUILD_CONTEXT=https://github.com/Raymoun17/stash-bff.git#main
# UI_BUILD_CONTEXT=https://github.com/Raymoun17/stash-ui.git#main
# SCRAPER_BUILD_CONTEXT=https://github.com/Raymoun17/stash-scraper-worker.git#main
#
# Private repositories (SSH agent/deploy key; see README):
# DB_BUILD_CONTEXT=git@github.com:Raymoun17/stash-db.git#main
# BFF_BUILD_CONTEXT=git@github.com:Raymoun17/stash-bff.git#main
# UI_BUILD_CONTEXT=git@github.com:Raymoun17/stash-ui.git#main
# SCRAPER_BUILD_CONTEXT=git@github.com:Raymoun17/stash-scraper-worker.git#main
